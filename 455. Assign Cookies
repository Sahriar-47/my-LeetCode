class Solution {
    public int findContentChildren(int[] g, int[] s) {
        int n1 = g.length;
        int n2 = s.length;
        Arrays.sort(g);
        Arrays.sort(s);

        int j = 0, i = 0;
        int ans = 0;
        while(j < n2) {
            if(j < n2 && i<n1) {
                if(s[j] >= g[i]) {
                    ans++;
                    i++;
                }
            }
            j++;
        }

        return ans;
    }
}



