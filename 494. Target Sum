class Solution {
    private int solve(int ind, int cur, int target, int[] nums, int[][] dp, int offset) {
        if(ind < 0) {
            if(cur == target) return 1;
            return 0;
        }

        if(dp[ind][cur+offset] != -1) return dp[ind][cur+offset];

        int add = solve(ind-1, cur+nums[ind], target, nums, dp, offset);
        int sub = solve(ind-1, cur-nums[ind], target, nums, dp, offset);

        return dp[ind][cur+offset] = add + sub;
    }
    public int findTargetSumWays(int[] nums, int target) {
        int n = nums.length;

        int sum = 0;
        for(int x: nums) sum += x;
        
        int[][] dp = new int[n][2*sum + 1];
        for(int[] ar: dp)
        Arrays.fill(ar, -1);

        return solve(n-1, 0, target, nums, dp, sum);
    }
}
