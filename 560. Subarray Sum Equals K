class Solution {
    public int subarraySum(int[] nums, int k) {
        int n = nums.length;

        int[] pre_sum = new int[n+1];
        pre_sum[0] = 0;
        for(int i=1; i<n+1; i++) {
            pre_sum[i] = pre_sum[i-1] + nums[i-1];
        }

        Map<Integer, Integer> mp = new HashMap<>();
        
        mp.put(0, 1);
        int res = 0;
        for(int i=1; i<n+1; i++) {            
            if(mp.containsKey(pre_sum[i] - k)) {
                res += mp.get(pre_sum[i]- k);
            }
            
            mp.put(pre_sum[i], mp.getOrDefault(pre_sum[i], 0) + 1);
        }
        return res;



