class Solution {
    public void rotate(int[] nums, int k) {
        int n = nums.length;
        int[] arr = new int[n];

        int j = 0;
        int seg = n-(k%n);
        for(int i=seg; i<n; i++) {
            arr[j] = nums[i];
            j++;
        }

        for(int i=0; i<seg; i++) {
            arr[j] = nums[i];
            j++;
        }

        for(int i=0; i<n; i++) {
            nums[i] = arr[i];
        }
    }
}
