class Solution {
    public void setZeroes(int[][] matrix) {
        int n = matrix.length;
        int m = matrix[0].length;

        for(int i=0; i<n; i++) {
            for(int j=0; j<m; j++) {
                if(matrix[i][j] == 0) {
                    for(int l=0; l<m; l++) {
                        if(matrix[i][l] != 0)
                        matrix[i][l] = (int)1e9+7;
                    }
                    for(int r=0; r<n; r++) {
                        if(matrix[r][j] != 0)
                        matrix[r][j] = (int)1e9+7;
                    }
                }
            }
        }

        for(int i=0; i<n; i++) {
            for(int j=0; j<m; j++) {
                if(matrix[i][j] == (int)1e9+7) 
                matrix[i][j] = 0;
            }
        }
    }
}



