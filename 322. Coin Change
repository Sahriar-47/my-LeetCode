class Solution {

    private int minCoins(int ind, int cur_sum, int target,
                         int[] arr, int[][] dp) {

        if (cur_sum == target) return 0;
        if (ind < 0 || cur_sum > target) return (int)1e9;

        if (dp[ind][cur_sum] != -1)
            return dp[ind][cur_sum];

        int take = (int)1e9;
        if (cur_sum + arr[ind] <= target) {
            take = 1 + minCoins(ind, cur_sum + arr[ind],
                                target, arr, dp);
        }

        int notTake = minCoins(ind - 1, cur_sum,
                               target, arr, dp);

        return dp[ind][cur_sum] = Math.min(take, notTake);
    }

    public int coinChange(int[] coins, int amount) {

        int n = coins.length;
        int[][] dp = new int[n][amount + 1];
        for (int[] row : dp)
            Arrays.fill(row, -1);

        int ans = minCoins(n - 1, 0, amount, coins, dp);

        return (ans >= 1e9) ? -1 : ans;
    }
}




