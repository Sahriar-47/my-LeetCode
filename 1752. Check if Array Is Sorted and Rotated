class Solution {
    public boolean check(int[] nums) {
        int n = nums.length;
        int[] target = nums.clone();
        Arrays.sort(target);

        for(int i=0; i<n; i++) {
            boolean ok = true;
            for(int ind=0; ind<n; ind++) {
                if(nums[(i+ind)%n] != target[ind]) {
                    ok = false;
                    break;
                }
            }
            if(ok) {
                return true;
            }
        }

        return false;
    }
}
